<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" name="AttendanceServiceLog4j2">

    <Appenders>

        <!-- CONSOLE APPENDER -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
                pattern="LOG4J2 %d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %c - %msg%n"/>
        </Console>

        <!-- FILE APPENDER -->
        <File name="FileLogger"
              fileName="logs/attendance-service.log"
              append="true"
              immediateFlush="true">
            <PatternLayout
                pattern="LOG4J2 %d{yyyy-MM-dd HH:mm:ss} %-5level %c - %msg%n"/>
        </File>

    </Appenders>

    <Loggers>

        <!-- ✅ ATTENDANCE SERVICE LOGS -->
        <Logger name="com.example.attendance_service"
                level="DEBUG"
                additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Logger>

        <!-- ROOT LOGGER -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>

    </Loggers>

</Configuration>
